# Copy to .env and fill in real values. All variables are optional; sane
# defaults are defined in config/settings.py.
CDT_ENVIRONMENT=development
CDT_LOG_LEVEL=INFO

# Override the DuckDB file location if needed
CDT_DUCKDB_PATH_OVERRIDE=

# External API base URLs (override only if endpoints change)
CDT_NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api
CDT_ERA5_CDS_URL=https://cds.climate.copernicus.eu/api/v2
CDT_SENTINEL_HUB_BASE_URL=https://services.sentinel-hub.com

# Networking
CDT_REQUEST_TIMEOUT_SECONDS=30
CDT_MAX_DOWNLOAD_RETRIES=3

# Caching
CDT_ENABLE_DISK_CACHE=true
CDT_CACHE_TTL_SECONDS=21600

# Forecasting
CDT_DEFAULT_FORECAST_HORIZON_DAYS=7
CDT_RANDOM_SEED=42
