__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.log
.DS_Store

# Data & model artifacts
storage/files/raw/*
!storage/files/raw/.gitkeep
storage/files/processed/*
!storage/files/processed/.gitkeep
storage/files/exports/*
!storage/files/exports/.gitkeep

# Ingested datasets & their sidecar metadata (downloaded at runtime)
data/raw/*
!data/raw/.gitkeep
data/metadata/*
!data/metadata/.gitkeep

# Runtime caches
storage/cache/.disk_cache/
storage/cache/.raster_cache/
ai/models/checkpoints/*.pt
ai/models/checkpoints/*.pth
*.duckdb
*.zarr/
